# refer to https://docs.nvidia.com/nemoclaw/latest/inference/switch-inference-providers.html
# to set a different provider or model

# ── Inference API credentials ─────────────────────────────────────
INFERENCE_API_KEY=

# ── Inference provider configuration ─────────────────────────────
INFERENCE_PROVIDER_TYPE=
INFERENCE_PROVIDER_NAME=
INFERENCE_BASE_URL=
INFERENCE_MODEL=

# ── PST file path (optional) ──────────────────────────────────────
# Absolute path to the Outlook .pst file the server should read.
# If omitted, the server falls back to the built-in sample PST.
PST_PATH=

# ── Aspose license (optional) ────────────────────────────────────
# Path to your Aspose.Email .lic file.
# Without a license, Aspose runs in evaluation mode (limited output).
ASPOSE_EMAIL_LICENSE_PATH=
