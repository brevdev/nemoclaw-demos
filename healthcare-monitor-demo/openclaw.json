            "process",
            "session_status"
          ],
          "deny": [
            "sessions_spawn",
            "sessions_send",
            "sessions_yield",
            "subagents"
          ]
        }
      },
      {
        "id": "payer-audit",
        "workspace": "/sandbox/.openclaw/workspace-payer-audit",
        "model": {
          "primary": "__MODEL_REF__"
        },
        "skills": [
          "healthcare-payer-audit",
          "healthcare-governance-egress"
        ],
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read",
            "exec",
