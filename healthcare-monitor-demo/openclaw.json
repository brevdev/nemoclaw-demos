            "session_status"
          ],
          "deny": [
            "sessions_spawn",
            "sessions_send",
            "sessions_yield",
            "subagents"
          ]
        }
      },
      {
        "id": "command-writer",
        "workspace": "/sandbox/.openclaw/workspace-command-writer",
        "model": {
          "primary": "__MODEL_REF__"
        },
        "skills": [
          "healthcare-command-summary",
          "healthcare-governance-egress"
        ],
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read",
            "exec",
            "process",
            "session_status"
          ],
          "deny": [
            "sessions_spawn",
            "sessions_send",
            "sessions_yield",
            "subagents"
          ]
        }
      }
    ]
  },
  "plugins": {
    "entries": {
      "acpx": {
        "enabled": false
      },
      "amazon-bedrock": {
        "enabled": false
      },
      "amazon-bedrock-mantle": {
