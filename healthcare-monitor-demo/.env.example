# Copy to .env on the Brev/runtime host only. Do not commit .env.
#
# Default release profile: NVIDIA build.nvidia.com/API Catalog with Nemotron Super.
# The setup script keeps these defaults unless NEMOCLAW_ALLOW_PROVIDER_OVERRIDE=1.
NVIDIA_API_KEY=
NEMOCLAW_ENDPOINT_URL=https://integrate.api.nvidia.com/v1/chat/completions
NEMOCLAW_SANDBOX=healthcare-monitor
NEMOCLAW_PROVIDER=build
NEMOCLAW_MODEL=nvidia/nemotron-3-super-120b-a12b
NEMOCLAW_ALLOW_PROVIDER_OVERRIDE=0

# Recommended enterprise pilot posture: start restricted, then add explicit policy.
NEMOCLAW_POLICY_TIER=restricted
NEMOCLAW_POLICY_MODE=suggested

# Optional setup controls.
NEMOCLAW_INSTALL_IF_MISSING=0
NEMOCLAW_ACCEPT_THIRD_PARTY_SOFTWARE=1
NEMOCLAW_DESTROY_EXISTING=0
NEMOCLAW_APPLY_LOCAL_POLICY=1

# Optional web app settings.
HOST=127.0.0.1
PORT=5188

# Optional provider override examples.
# Keep the default release profile above for the packaged demo. To test another
# provider, set NEMOCLAW_ALLOW_PROVIDER_OVERRIDE=1, choose one provider block,
# and rebuild the sandbox.
#
# OpenAI:
# OPENAI_API_KEY=
# NEMOCLAW_PROVIDER=openai
# NEMOCLAW_MODEL=<openai-model-id>
#
# Anthropic:
# ANTHROPIC_API_KEY=
# NEMOCLAW_PROVIDER=anthropic
# NEMOCLAW_MODEL=<anthropic-model-id>
#
# Gemini:
# GEMINI_API_KEY=
# NEMOCLAW_PROVIDER=gemini
# NEMOCLAW_MODEL=<gemini-model-id>
#
# OpenAI-compatible custom Chat Completions provider:
# NEMOCLAW_PROVIDER=custom
# NEMOCLAW_PROVIDER_KEY=
# NEMOCLAW_ENDPOINT_URL=https://provider.example.com/v1/chat/completions
# NEMOCLAW_MODEL=provider/model-id
